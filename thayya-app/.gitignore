# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (never commit secrets; allow committed examples)
.env*
!.env.example
!.env*.example

# vercel
.vercel

# supabase CLI (local link / version cache — not portable, may contain project refs)
supabase/.temp/

# turbopack
.turbo/

# editors (optional local settings)
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# typescript
*.tsbuildinfo
next-env.d.ts

# local v0 unpack scratch (do not commit)
/_v0-dashboard-unpack

certificates